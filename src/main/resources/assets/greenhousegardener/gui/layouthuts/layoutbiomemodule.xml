<window xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/ldtteam/BlockUI/version/1.20.1/src/main/resources/assets/blockui/gui/block_ui.xsd"
    size="190 244">
    <image source="minecolonies:textures/gui/builderhut/builder_paper.png" size="190 244"/>
    <image id="help" source="greenhousegardener:textures/gui/modules/help.png" size="11 11" pos="150 17" visible="true"/>

    <text id="desc" size="130 11" pos="30 14" color="black" textalign="MIDDLE"/>

    <text id="fieldSummary" size="174 22" pos="8 28" color="black" textalign="MIDDLE"/>

    <list id="fields" size="174 131" pos="8 51" emptytext="$(com.greenhousegardener.core.gui.biome.fields.empty)" emptycolor="black">
        <box size="168 26" linewidth="1">
            <itemicon id="seed" size="16 16" pos="4 5"/>
            <checkbox id="owned" size="14 14" pos="27 6" source="minecolonies:textures/gui/builderhut/builder_button_very_small.png"
                    checkmark="minecolonies:textures/gui/builderhut/builder_button_mini_check.png"/>
            <dropdown id="temp" size="54 17" pos="48 5" dropDownSize="75 55" maxContentHeight="55" textcolor="black"
                    source="minecolonies:textures/gui/builderhut/builder_button_medium.png">
                <button id="button" size="54 17" pos="0 0" textcolor="black"
                        source="minecolonies:textures/gui/builderhut/builder_button_medium.png"/>
            </dropdown>
            <dropdown id="humidity" size="54 17" pos="108 5" dropDownSize="75 55" maxContentHeight="55" textcolor="black"
                    source="minecolonies:textures/gui/builderhut/builder_button_very_small.png">
                <button id="button" size="54 17" pos="0 0" textcolor="black"
                        source="minecolonies:textures/gui/builderhut/builder_button_very_small.png"/>
            </dropdown>
        </box>
    </list>

    <box size="168 48" pos="11 186" linewidth="1">
        <text size="150 11" pos="9 3" color="black" textalign="MIDDLE" label="$(com.greenhousegardener.core.gui.biome.balance.title)"/>
        <text size="43 11" pos="5 17" color="black" textalign="MIDDLE_LEFT" label="$(com.greenhousegardener.core.gui.biome.balance.temp)"/>
        <text size="32 11" pos="55 17" color="black" textalign="MIDDLE_LEFT" label="$(com.greenhousegardener.core.gui.biome.balance.hot)"/>
        <text id="hotBalance" size="28 11" pos="85 17" color="black" textalign="MIDDLE_LEFT"/>
        <text size="32 11" pos="115 17" color="black" textalign="MIDDLE_LEFT" label="$(com.greenhousegardener.core.gui.biome.balance.cold)"/>
        <text id="coldBalance" size="26 11" pos="145 17" color="black" textalign="MIDDLE_LEFT"/>
        <text size="43 11" pos="5 32" color="black" textalign="MIDDLE_LEFT" label="$(com.greenhousegardener.core.gui.biome.balance.humidity)"/>
        <text size="32 11" pos="55 32" color="black" textalign="MIDDLE_LEFT" label="$(com.greenhousegardener.core.gui.biome.balance.humid)"/>
        <text id="humidBalance" size="28 11" pos="85 32" color="black" textalign="MIDDLE_LEFT"/>
        <text size="32 11" pos="115 32" color="black" textalign="MIDDLE_LEFT" label="$(com.greenhousegardener.core.gui.biome.balance.dry)"/>
        <text id="dryBalance" size="26 11" pos="145 32" color="black" textalign="MIDDLE_LEFT"/>
    </box>


</window>
