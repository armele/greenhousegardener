            <button label="X" id="removeDecrease" pos="131 1" size="29 15"
                source="minecolonies:textures/gui/builderhut/builder_button_very_small.png" color="red"/>
        </box>
    </list>

    <text size="180 11" pos="5 219" textalign="MIDDLE" color="black"
        label="$(com.greenhousegardener.core.gui.climate.quantity.protected)"
        tooltip="$(com.greenhousegardener.core.gui.climate.quantity.protected.tooltip)"/>
