            <itemicon id="itemIcon" size="17 17" pos="0 0"/>
            <text id="itemName" size="85 12" pos="20 1" color="black"/>
            <text id="itemClimateModificationUnit" size="18 12" pos="112 1" color="black"
                tooltip="$(com.greenhousegardener.core.gui.climate.modification_unit.tooltip)"/>
